# Sasso Radar Tower — environment configuration
# Copy to .env and adjust values as needed.

# Home location (lat/lon in decimal degrees)
FLUGRADAR_HOME_LAT=47.3769
FLUGRADAR_HOME_LON=8.5417

# Scan radius in kilometres
FLUGRADAR_RADIUS_KM=100

# Poll interval for live positions (seconds)
FLUGRADAR_POLL_INTERVAL=3

# Distance display unit: km | sm | nm
FLUGRADAR_DISTANCE_UNIT=km

# Display theme: dark | amber
FLUGRADAR_THEME=dark

# Minimum altitude filter (feet) — aircraft below this are hidden
FLUGRADAR_MIN_ALT_FT=0

# Optional API keys (leave empty to run with adsb.fi only)
FR24_API_KEY=
TOMORROW_API_KEY=
AIRLABS_API_KEY=
